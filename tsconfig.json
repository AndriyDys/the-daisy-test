{
  "compilerOptions": {
    "target": "es2021",
    "module": "esnext",
    "lib": ["DOM", "DOM.Iterable", "ES2021"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["./*.js"]
}
